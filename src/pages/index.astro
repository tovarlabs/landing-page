---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Tovarlabs - Soluciones Digitales a Medida">
    <Header />

    <main>
        <!-- Hero Section -->
        <section
            id="inicio"
            class="relative min-h-screen flex items-center justify-center bg-gradient-to-br from-secondary via-secondary-dark to-secondary pt-16 overflow-hidden"
        >
            <!-- Animated background grid -->
            <div class="absolute inset-0 opacity-10">
                <div
                    class="absolute inset-0"
                    style="background-image: linear-gradient(#00ffca 1px, transparent 1px), linear-gradient(90deg, #00ffca 1px, transparent 1px); background-size: 50px 50px;"
                >
                </div>
            </div>

            <!-- Floating tech shapes -->
            <div class="absolute inset-0 overflow-hidden pointer-events-none">
                <div
                    class="tech-shape tech-shape-1 absolute w-64 h-64 bg-primary/5 rounded-full blur-3xl"
                >
                </div>
                <div
                    class="tech-shape tech-shape-2 absolute w-96 h-96 bg-primary/10 rounded-full blur-3xl"
                >
                </div>
                <div
                    class="tech-shape tech-shape-3 absolute w-48 h-48 bg-primary/5 rounded-full blur-3xl"
                >
                </div>
            </div>

            <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                    <!-- Content Column -->
                    <div class="hero-content">
                        <!-- Trust Badge -->
                        <div
                            class="inline-flex items-center gap-2 bg-primary/10 backdrop-blur-sm border border-primary/20 rounded-full px-4 py-2 mb-6"
                        >
                            <svg
                                class="w-5 h-5 text-primary"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                                ></path>
                            </svg>
                            <span class="text-sm font-medium text-primary"
                                >+6 años transformando negocios digitalmente</span
                            >
                        </div>

                        <!-- Main Headline -->
                        <h1
                            class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight"
                        >
                            Convierte tu negocio en una
                            <span class="text-primary block mt-2 hero-highlight"
                                >máquina digital eficiente</span
                            >
                        </h1>

                        <!-- Subheadline -->
                        <p class="text-xl md:text-2xl text-gray-300 mb-8 max-w-2xl leading-relaxed">
                            Automatiza procesos, reduce costos operativos y escala tu negocio con
                            tecnología web personalizada.
                        </p>

                        <!-- Value Props -->
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
                            <div class="flex items-center gap-2">
                                <svg
                                    class="w-5 h-5 text-primary flex-shrink-0"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path>
                                </svg>
                                <span class="text-gray-300 text-sm">Sin plantillas</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <svg
                                    class="w-5 h-5 text-primary flex-shrink-0"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path>
                                </svg>
                                <span class="text-gray-300 text-sm">100% a medida</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <svg
                                    class="w-5 h-5 text-primary flex-shrink-0"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path>
                                </svg>
                                <span class="text-gray-300 text-sm">Soporte continuo</span>
                            </div>
                        </div>

                        <!-- CTAs -->
                        <div class="flex flex-col sm:flex-row gap-4">
                            <a
                                href="#contacto"
                                class="group inline-flex items-center justify-center gap-2 bg-primary text-secondary px-8 py-4 rounded-xl text-lg font-semibold hover:bg-primary-light transition-all shadow-lg shadow-primary/25 hover:shadow-primary/40 hover:-translate-y-0.5"
                            >
                                <span>Solicitar cotización</span>
                                <svg
                                    class="w-5 h-5 group-hover:translate-x-1 transition-transform"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                                </svg>
                            </a>
                            <a
                                href="#servicios"
                                class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur-sm border-2 border-primary/30 text-white px-8 py-4 rounded-xl text-lg font-semibold hover:bg-white/20 hover:border-primary/50 transition-all"
                            >
                                <svg
                                    class="w-5 h-5"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                                    ></path>
                                </svg>
                                <span>Ver proyectos</span>
                            </a>
                        </div>
                    </div>

                    <!-- Visual Column -->
                    <div class="relative hero-visual hidden lg:block">
                        <!-- Tech Dashboard Mockup -->
                        <div class="relative">
                            <!-- Main card -->
                            <div
                                class="relative bg-white/5 backdrop-blur-md border border-primary/20 rounded-2xl p-6 shadow-2xl"
                            >
                                <!-- Header -->
                                <div class="flex items-center justify-between mb-6">
                                    <div class="flex items-center gap-3">
                                        <div
                                            class="w-10 h-10 rounded-lg bg-primary/20 flex items-center justify-center"
                                        >
                                            <svg
                                                class="w-6 h-6 text-primary"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                                                ></path>
                                            </svg>
                                        </div>
                                        <div>
                                            <div class="h-3 w-24 bg-white/20 rounded mb-1"></div>
                                            <div class="h-2 w-16 bg-white/10 rounded"></div>
                                        </div>
                                    </div>
                                    <div class="flex gap-2">
                                        <div class="w-2 h-2 rounded-full bg-red-400/50"></div>
                                        <div class="w-2 h-2 rounded-full bg-yellow-400/50"></div>
                                        <div class="w-2 h-2 rounded-full bg-green-400/50"></div>
                                    </div>
                                </div>

                                <!-- Stats Grid -->
                                <div class="grid grid-cols-2 gap-4 mb-6">
                                    <div
                                        class="bg-primary/5 border border-primary/10 rounded-xl p-4"
                                    >
                                        <div class="h-2 w-12 bg-primary/30 rounded mb-2"></div>
                                        <div class="h-6 w-20 bg-primary/50 rounded mb-1"></div>
                                        <div class="h-2 w-16 bg-white/10 rounded"></div>
                                    </div>
                                    <div
                                        class="bg-primary/5 border border-primary/10 rounded-xl p-4"
                                    >
                                        <div class="h-2 w-12 bg-primary/30 rounded mb-2"></div>
                                        <div class="h-6 w-20 bg-primary/50 rounded mb-1"></div>
                                        <div class="h-2 w-16 bg-white/10 rounded"></div>
                                    </div>
                                </div>

                                <!-- Chart -->
                                <div class="relative h-32 flex items-end gap-2">
                                    <div class="chart-bar bg-primary/30 rounded-t"></div>
                                    <div class="chart-bar bg-primary/50 rounded-t"></div>
                                    <div class="chart-bar bg-primary/40 rounded-t"></div>
                                    <div class="chart-bar bg-primary/70 rounded-t"></div>
                                    <div class="chart-bar bg-primary/60 rounded-t"></div>
                                    <div class="chart-bar bg-primary rounded-t"></div>
                                    <div class="chart-bar bg-primary/50 rounded-t"></div>
                                </div>
                            </div>

                            <!-- Floating metric cards -->
                            <div
                                class="floating-card absolute -top-6 -right-6 bg-white/10 backdrop-blur-sm border border-primary/20 rounded-xl p-4 shadow-xl"
                            >
                                <div class="flex items-center gap-3">
                                    <div
                                        class="w-12 h-12 rounded-full bg-green-500/20 flex items-center justify-center"
                                    >
                                        <svg
                                            class="w-6 h-6 text-green-400"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                                        </svg>
                                    </div>
                                    <div>
                                        <div class="text-xs text-gray-400">Crecimiento</div>
                                        <div class="text-lg font-bold text-white">+156%</div>
                                    </div>
                                </div>
                            </div>

                            <div
                                class="floating-card-2 absolute -bottom-4 -left-6 bg-white/10 backdrop-blur-sm border border-primary/20 rounded-xl p-4 shadow-xl"
                            >
                                <div class="flex items-center gap-3">
                                    <div
                                        class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center"
                                    >
                                        <svg
                                            class="w-6 h-6 text-primary"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                            ></path>
                                        </svg>
                                    </div>
                                    <div>
                                        <div class="text-xs text-gray-400">Ahorro tiempo</div>
                                        <div class="text-lg font-bold text-white">-65%</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Services Section -->
        <section id="servicios" class="py-20 bg-gray-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <h2 class="text-4xl md:text-5xl font-bold text-secondary mb-4">
                        ¿Qué hacemos en <span class="text-primary">Tovarlabs?</span>
                    </h2>
                    <p class="text-xl text-gray-600 max-w-3xl mx-auto">
                        Diseñamos y desarrollamos soluciones digitales que impulsan tu negocio
                    </p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    <!-- Web Pages -->
                    <div
                        class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-shadow border-t-4 border-primary"
                    >
                        <div class="text-5xl mb-4">🌐</div>
                        <h3 class="text-2xl font-bold text-secondary mb-4">
                            Páginas Web Profesionales
                        </h3>
                        <p class="text-gray-600 mb-6">
                            Diseñamos sitios web modernos y efectivos que convierten visitantes en
                            clientes.
                        </p>
                        <ul class="space-y-3">
                            <li class="flex items-start">
                                <span class="text-primary mr-2">✓</span>
                                <span class="text-gray-700">Landing pages de alto impacto</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary mr-2">✓</span>
                                <span class="text-gray-700">Sitios corporativos profesionales</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary mr-2">✓</span>
                                <span class="text-gray-700">Webs para negocios locales</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary mr-2">✓</span>
                                <span class="text-gray-700"
                                    >Páginas optimizadas para conversión</span
                                >
                            </li>
                        </ul>
                    </div>

                    <!-- Web Systems -->
                    <div
                        class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-shadow border-t-4 border-primary-dark"
                    >
                        <div class="text-5xl mb-4">⚙️</div>
                        <h3 class="text-2xl font-bold text-secondary mb-4">
                            Sistemas Web a la Medida
                        </h3>
                        <p class="text-gray-600 mb-6">
                            Desarrollamos sistemas personalizados que automatizan y optimizan tus
                            procesos.
                        </p>
                        <ul class="space-y-3">
                            <li class="flex items-start">
                                <span class="text-primary mr-2">✓</span>
                                <span class="text-gray-700">Paneles administrativos intuitivos</span
                                >
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary mr-2">✓</span>
                                <span class="text-gray-700">Gestión de clientes y ventas</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary mr-2">✓</span>
                                <span class="text-gray-700"
                                    >Sistemas de operaciones y logística</span
                                >
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary mr-2">✓</span>
                                <span class="text-gray-700">Automatización de procesos</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Integration -->
                    <div
                        class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-shadow border-t-4 border-primary-light"
                    >
                        <div class="text-5xl mb-4">🔗</div>
                        <h3 class="text-2xl font-bold text-secondary mb-4">Integración Completa</h3>
                        <p class="text-gray-600 mb-6">
                            Conectamos tu página web con tus sistemas internos para una operación
                            fluida.
                        </p>
                        <ul class="space-y-3">
                            <li class="flex items-start">
                                <span class="text-primary mr-2">✓</span>
                                <span class="text-gray-700">Web conectada con tu sistema</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary mr-2">✓</span>
                                <span class="text-gray-700">Formularios a tu panel de control</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary mr-2">✓</span>
                                <span class="text-gray-700">Registro automático de clientes</span>
                            </li>
                            <li class="flex items-start">
                                <span class="text-primary mr-2">✓</span>
                                <span class="text-gray-700"
                                    >Digitalización de procesos manuales</span
                                >
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Work Process -->
        <section id="como-trabajamos" class="py-20 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <h2 class="text-4xl md:text-5xl font-bold text-secondary mb-4">
                        ¿Cómo <span class="text-primary">trabajamos?</span>
                    </h2>
                    <p class="text-xl text-gray-600 max-w-3xl mx-auto">
                        Un proceso simple y transparente para llevar tu proyecto a la realidad
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                    <div class="text-center">
                        <div
                            class="bg-primary text-secondary w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4"
                        >
                            1
                        </div>
                        <h3 class="text-xl font-bold text-secondary mb-2">Conversación inicial</h3>
                        <p class="text-gray-600">Entendemos tus necesidades y objetivos</p>
                    </div>

                    <div class="text-center">
                        <div
                            class="bg-primary text-secondary w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4"
                        >
                            2
                        </div>
                        <h3 class="text-xl font-bold text-secondary mb-2">Propuesta y diseño</h3>
                        <p class="text-gray-600">Creamos una solución personalizada para ti</p>
                    </div>

                    <div class="text-center">
                        <div
                            class="bg-primary text-secondary w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4"
                        >
                            3
                        </div>
                        <h3 class="text-xl font-bold text-secondary mb-2">Desarrollo</h3>
                        <p class="text-gray-600">Construimos tu solución con tecnología moderna</p>
                    </div>

                    <div class="text-center">
                        <div
                            class="bg-primary text-secondary w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4"
                        >
                            4
                        </div>
                        <h3 class="text-xl font-bold text-secondary mb-2">Lanzamiento</h3>
                        <p class="text-gray-600">Ponemos en marcha y te acompañamos</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Why Choose Us -->
        <section class="py-20 bg-gradient-to-br from-secondary to-secondary-dark text-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <h2 class="text-4xl md:text-5xl font-bold mb-4">
                        ¿Por qué elegir <span class="text-primary">Tovarlabs?</span>
                    </h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <div class="text-center">
                        <div class="text-4xl mb-4">💡</div>
                        <h3 class="text-xl font-bold mb-2">Soluciones a medida</h3>
                        <p class="text-gray-300">
                            No usamos plantillas. Cada proyecto se diseña específicamente para tu
                            negocio.
                        </p>
                    </div>

                    <div class="text-center">
                        <div class="text-4xl mb-4">🚀</div>
                        <h3 class="text-xl font-bold mb-2">Tecnología moderna</h3>
                        <p class="text-gray-300">
                            Usamos las últimas tecnologías para crear soluciones rápidas y
                            escalables.
                        </p>
                    </div>

                    <div class="text-center">
                        <div class="text-4xl mb-4">
                            <svg
                                class="inline-block w-12 h-12"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="text-xl font-bold mb-2">Diseño responsive</h3>
                        <p class="text-gray-300">
                            Tus clientes tendrán una experiencia perfecta desde cualquier
                            dispositivo.
                        </p>
                    </div>

                    <div class="text-center">
                        <div class="text-4xl mb-4">🔒</div>
                        <h3 class="text-xl font-bold mb-2">Seguro y confiable</h3>
                        <p class="text-gray-300">
                            Implementamos las mejores prácticas de seguridad para proteger tu
                            información.
                        </p>
                    </div>

                    <div class="text-center">
                        <div class="text-4xl mb-4">⚡</div>
                        <h3 class="text-xl font-bold mb-2">Optimizado para conversión</h3>
                        <p class="text-gray-300">
                            Diseñamos pensando en tus objetivos de negocio y tasas de conversión.
                        </p>
                    </div>

                    <div class="text-center">
                        <div class="text-4xl mb-4">🤝</div>
                        <h3 class="text-xl font-bold mb-2">Soporte continuo</h3>
                        <p class="text-gray-300">
                            Te acompañamos después del lanzamiento para asegurar tu éxito.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Contact Section -->
        <section id="contacto" class="py-20 bg-gray-50">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-12">
