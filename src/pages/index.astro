---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Tovarlabs - Soluciones Digitales a Medida">
    <Header />

    <main>
        <!-- Hero Section -->
        <section
            id="inicio"
            class="relative min-h-screen flex items-center justify-center bg-gradient-to-br from-secondary via-secondary-dark to-secondary pt-16 overflow-hidden"
        >
            <!-- Animated background grid -->
            <div class="absolute inset-0 opacity-10">
                <div
                    class="absolute inset-0"
                    style="background-image: linear-gradient(#00ffca 1px, transparent 1px), linear-gradient(90deg, #00ffca 1px, transparent 1px); background-size: 50px 50px;"
                >
                </div>
            </div>

            <!-- Floating tech shapes -->
            <div class="absolute inset-0 overflow-hidden pointer-events-none">
                <div
                    class="tech-shape tech-shape-1 absolute w-64 h-64 bg-primary/5 rounded-full blur-3xl"
                >
                </div>
                <div
                    class="tech-shape tech-shape-2 absolute w-96 h-96 bg-primary/10 rounded-full blur-3xl"
                >
                </div>
                <div
                    class="tech-shape tech-shape-3 absolute w-48 h-48 bg-primary/5 rounded-full blur-3xl"
                >
                </div>
            </div>

            <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                    <!-- Content Column -->
                    <div class="hero-content">
                        <!-- Trust Badge -->
                        <div
                            class="inline-flex items-center gap-2 bg-primary/10 backdrop-blur-sm border border-primary/20 rounded-full px-4 py-2 mb-6"
                        >
                            <svg
                                class="w-5 h-5 text-primary"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                                ></path>
                            </svg>
                            <span class="text-sm font-medium text-primary"
                                >+6 años transformando negocios digitalmente</span
                            >
                        </div>

                        <!-- Main Headline -->
                        <h1
                            class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight"
                        >
                            Convierte tu negocio en una
                            <span class="text-primary block mt-2 hero-highlight"
                                >máquina digital eficiente</span
                            >
                        </h1>

                        <!-- Subheadline -->
                        <p class="text-xl md:text-2xl text-gray-300 mb-8 max-w-2xl leading-relaxed">
                            Automatiza procesos, reduce costos operativos y escala tu negocio con
                            tecnología web personalizada.
                        </p>

                        <!-- Value Props -->
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
                            <div class="flex items-center gap-2">
                                <svg
                                    class="w-5 h-5 text-primary flex-shrink-0"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path>
                                </svg>
                                <span class="text-gray-300 text-sm">Sin plantillas</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <svg
                                    class="w-5 h-5 text-primary flex-shrink-0"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path>
                                </svg>
                                <span class="text-gray-300 text-sm">100% a medida</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <svg
                                    class="w-5 h-5 text-primary flex-shrink-0"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path>
                                </svg>
                                <span class="text-gray-300 text-sm">Soporte continuo</span>
                            </div>
                        </div>

                        <!-- CTAs -->
                        <div class="flex flex-col sm:flex-row gap-4">
                            <a
                                href="#contacto"
                                class="group inline-flex items-center justify-center gap-2 bg-primary text-secondary px-8 py-4 rounded-xl text-lg font-semibold hover:bg-primary-light transition-all shadow-lg shadow-primary/25 hover:shadow-primary/40 hover:-translate-y-0.5"
                            >
                                <span>Solicitar cotización</span>
                                <svg
                                    class="w-5 h-5 group-hover:translate-x-1 transition-transform"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                                </svg>
                            </a>
                            <a
                                href="#servicios"
                                class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur-sm border-2 border-primary/30 text-white px-8 py-4 rounded-xl text-lg font-semibold hover:bg-white/20 hover:border-primary/50 transition-all"
                            >
                                <svg
                                    class="w-5 h-5"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                                    ></path>
                                </svg>
                                <span>Ver proyectos</span>
                            </a>
                        </div>
                    </div>

                    <!-- Visual Column -->
                    <div class="relative hero-visual hidden lg:block">
                        <!-- Tech Dashboard Mockup -->
                        <div class="relative">
                            <!-- Main card -->
                            <div
                                class="relative bg-white/5 backdrop-blur-md border border-primary/20 rounded-2xl p-6 shadow-2xl"
                            >
                                <!-- Header -->
                                <div class="flex items-center justify-between mb-6">
                                    <div class="flex items-center gap-3">
                                        <div
                                            class="w-10 h-10 rounded-lg bg-primary/20 flex items-center justify-center"
                                        >
                                            <svg
                                                class="w-6 h-6 text-primary"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                                                ></path>
                                            </svg>
                                        </div>
                                        <div>
                                            <div class="h-3 w-24 bg-white/20 rounded mb-1"></div>
                                            <div class="h-2 w-16 bg-white/10 rounded"></div>
                                        </div>
                                    </div>
                                    <div class="flex gap-2">
                                        <div class="w-2 h-2 rounded-full bg-red-400/50"></div>
                                        <div class="w-2 h-2 rounded-full bg-yellow-400/50"></div>
                                        <div class="w-2 h-2 rounded-full bg-green-400/50"></div>
                                    </div>
                                </div>

                                <!-- Stats Grid -->
                                <div class="grid grid-cols-2 gap-4 mb-6">
                                    <div
                                        class="bg-primary/5 border border-primary/10 rounded-xl p-4"
                                    >
                                        <div class="h-2 w-12 bg-primary/30 rounded mb-2"></div>
                                        <div class="h-6 w-20 bg-primary/50 rounded mb-1"></div>
                                        <div class="h-2 w-16 bg-white/10 rounded"></div>
                                    </div>
                                    <div
                                        class="bg-primary/5 border border-primary/10 rounded-xl p-4"
                                    >
                                        <div class="h-2 w-12 bg-primary/30 rounded mb-2"></div>
                                        <div class="h-6 w-20 bg-primary/50 rounded mb-1"></div>
                                        <div class="h-2 w-16 bg-white/10 rounded"></div>
                                    </div>
                                </div>

                                <!-- Chart -->
                                <div class="relative h-32 flex items-end gap-2">
                                    <div class="chart-bar bg-primary/30 rounded-t"></div>
                                    <div class="chart-bar bg-primary/50 rounded-t"></div>
                                    <div class="chart-bar bg-primary/40 rounded-t"></div>
                                    <div class="chart-bar bg-primary/70 rounded-t"></div>
                                    <div class="chart-bar bg-primary/60 rounded-t"></div>
                                    <div class="chart-bar bg-primary rounded-t"></div>
                                    <div class="chart-bar bg-primary/50 rounded-t"></div>
                                </div>
                            </div>

                            <!-- Floating metric cards -->
                            <div
                                class="floating-card absolute -top-6 -right-6 bg-white/10 backdrop-blur-sm border border-primary/20 rounded-xl p-4 shadow-xl"
                            >
                                <div class="flex items-center gap-3">
                                    <div
                                        class="w-12 h-12 rounded-full bg-green-500/20 flex items-center justify-center"
                                    >
                                        <svg
                                            class="w-6 h-6 text-green-400"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                                        </svg>
                                    </div>
                                    <div>
                                        <div class="text-xs text-gray-400">Crecimiento</div>
                                        <div class="text-lg font-bold text-white">+156%</div>
                                    </div>
                                </div>
                            </div>

                            <div
                                class="floating-card-2 absolute -bottom-4 -left-6 bg-white/10 backdrop-blur-sm border border-primary/20 rounded-xl p-4 shadow-xl"
                            >
                                <div class="flex items-center gap-3">
                                    <div
                                        class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center"
                                    >
                                        <svg
                                            class="w-6 h-6 text-primary"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                            ></path>
                                        </svg>
                                    </div>
                                    <div>
                                        <div class="text-xs text-gray-400">Ahorro tiempo</div>
                                        <div class="text-lg font-bold text-white">-65%</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Services Section -->
        <section id="servicios" class="py-24 bg-gradient-to-b from-gray-50 to-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <!-- Header -->
                <div class="text-center mb-20">
                    <div
                        class="inline-flex items-center gap-2 bg-primary/10 border border-primary/20 rounded-full px-4 py-2 mb-6"
                    >
                        <svg
                            class="w-5 h-5 text-primary"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                        <span class="text-sm font-medium text-primary">Servicios principales</span>
                    </div>
                    <h2 class="text-4xl md:text-5xl font-bold text-secondary mb-6">
                        Transformamos ideas en
                        <span class="text-primary block mt-2">soluciones digitales</span>
                    </h2>
                    <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
                        Desde tu presencia online hasta sistemas complejos que impulsan tu operación
                    </p>
                </div>

                <!-- Services Grid -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    <!-- Service Card 1: Web Pages -->
                    <div
                        class="service-card group relative bg-white rounded-2xl p-8 border border-gray-200 hover:border-primary/50 transition-all duration-300 hover:shadow-2xl hover:-translate-y-2"
                    >
                        <!-- Icon Container -->
                        <div class="relative mb-6">
                            <div
                                class="w-16 h-16 rounded-2xl bg-gradient-to-br from-primary/20 to-primary/5 flex items-center justify-center group-hover:scale-110 transition-transform duration-300"
                            >
                                <svg
                                    class="w-8 h-8 text-primary"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
                                    ></path>
                                </svg>
                            </div>
                            <!-- Decorative Element -->
                            <div
                                class="absolute -top-1 -right-1 w-6 h-6 bg-primary/20 rounded-full blur-md group-hover:bg-primary/40 transition-colors"
                            >
                            </div>
                        </div>

                        <!-- Title -->
                        <h3
                            class="text-2xl font-bold text-secondary mb-3 group-hover:text-primary transition-colors"
                        >
                            Páginas Web Profesionales
                        </h3>

                        <!-- Description -->
                        <p class="text-gray-600 mb-6 leading-relaxed">
                            Sitios web modernos y efectivos que convierten visitantes en clientes y
                            fortalecen tu marca.
                        </p>

                        <!-- Main Benefit Badge -->
                        <div
                            class="inline-flex items-center gap-2 bg-green-50 border border-green-200 rounded-lg px-3 py-2 mb-6"
                        >
                            <svg
                                class="w-4 h-4 text-green-600"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                ></path>
                            </svg>
                            <span class="text-sm font-semibold text-green-700"
                                >ROI medible desde el día 1</span
                            >
                        </div>

                        <!-- Features List -->
                        <ul class="space-y-3">
                            <li class="flex items-start gap-3">
                                <svg
                                    class="w-5 h-5 text-primary mt-0.5 flex-shrink-0"
                                    fill="currentColor"
                                    viewBox="0 0 20 20"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                        clip-rule="evenodd"></path>
                                </svg>
                                <span class="text-gray-700"
                                    >Landing pages optimizadas para conversión</span
                                >
                            </li>
                            <li class="flex items-start gap-3">
                                <svg
                                    class="w-5 h-5 text-primary mt-0.5 flex-shrink-0"
                                    fill="currentColor"
                                    viewBox="0 0 20 20"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                        clip-rule="evenodd"></path>
                                </svg>
                                <span class="text-gray-700"
                                    >Sitios corporativos con identidad única</span
                                >
                            </li>
                            <li class="flex items-start gap-3">
                                <svg
                                    class="w-5 h-5 text-primary mt-0.5 flex-shrink-0"
                                    fill="currentColor"
                                    viewBox="0 0 20 20"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                        clip-rule="evenodd"></path>
                                </svg>
                                <span class="text-gray-700">SEO y performance optimizados</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <svg
                                    class="w-5 h-5 text-primary mt-0.5 flex-shrink-0"
                                    fill="currentColor"
                                    viewBox="0 0 20 20"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                        clip-rule="evenodd"></path>
                                </svg>
                                <span class="text-gray-700">Diseño responsive y accesible</span>
                            </li>
                        </ul>

                        <!-- Hover Border Effect -->
                        <div
                            class="absolute inset-0 rounded-2xl bg-gradient-to-br from-primary/0 to-primary/0 group-hover:from-primary/5 group-hover:to-transparent pointer-events-none transition-all duration-300"
                        >
                        </div>
                    </div>

                    <!-- Service Card 2: Web Systems -->
                    <div
                        class="service-card group relative bg-white rounded-2xl p-8 border border-gray-200 hover:border-primary/50 transition-all duration-300 hover:shadow-2xl hover:-translate-y-2"
                    >
                        <!-- Icon Container -->
                        <div class="relative mb-6">
                            <div
                                class="w-16 h-16 rounded-2xl bg-gradient-to-br from-secondary/20 to-secondary/5 flex items-center justify-center group-hover:scale-110 transition-transform duration-300"
                            >
                                <svg
                                    class="w-8 h-8 text-secondary"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"
                                    ></path>
                                </svg>
                            </div>
                            <div
                                class="absolute -top-1 -right-1 w-6 h-6 bg-secondary/20 rounded-full blur-md group-hover:bg-secondary/40 transition-colors"
                            >
                            </div>
                        </div>

                        <!-- Title -->
                        <h3
                            class="text-2xl font-bold text-secondary mb-3 group-hover:text-primary transition-colors"
                        >
                            Sistemas Web a Medida
                        </h3>

                        <!-- Description -->
                        <p class="text-gray-600 mb-6 leading-relaxed">
                            Soluciones personalizadas que automatizan procesos y optimizan la
                            gestión de tu negocio.
                        </p>

                        <!-- Main Benefit Badge -->
                        <div
                            class="inline-flex items-center gap-2 bg-blue-50 border border-blue-200 rounded-lg px-3 py-2 mb-6"
                        >
                            <svg
                                class="w-4 h-4 text-blue-600"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                ></path>
                            </svg>
                            <span class="text-sm font-semibold text-blue-700"
                                >Ahorra +60% de tiempo operativo</span
                            >
                        </div>

                        <!-- Features List -->
                        <ul class="space-y-3">
                            <li class="flex items-start gap-3">
                                <svg
                                    class="w-5 h-5 text-primary mt-0.5 flex-shrink-0"
                                    fill="currentColor"
                                    viewBox="0 0 20 20"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                        clip-rule="evenodd"></path>
                                </svg>
                                <span class="text-gray-700"
                                    >Dashboards administrativos intuitivos</span
                                >
                            </li>
                            <li class="flex items-start gap-3">
                                <svg
                                    class="w-5 h-5 text-primary mt-0.5 flex-shrink-0"
                                    fill="currentColor"
                                    viewBox="0 0 20 20"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                        clip-rule="evenodd"></path>
                                </svg>
                                <span class="text-gray-700">CRM y gestión de clientes</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <svg
                                    class="w-5 h-5 text-primary mt-0.5 flex-shrink-0"
                                    fill="currentColor"
                                    viewBox="0 0 20 20"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                        clip-rule="evenodd"></path>
                                </svg>
                                <span class="text-gray-700"
                                    >Automatización de flujos de trabajo</span
                                >
                            </li>
                            <li class="flex items-start gap-3">
                                <svg
                                    class="w-5 h-5 text-primary mt-0.5 flex-shrink-0"
                                    fill="currentColor"
                                    viewBox="0 0 20 20"
                                >
                                    <path
                                        fill-rule="evenodd"
