---
const currentYear = new Date().getFullYear();
---

<footer class="bg-secondary text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Contact -->
            <div>
                <div class="flex items-center gap-3 mb-4">
                    <img src="/logo.png" alt="Tovarlabs" class="h-10 w-auto" />
                    <h3 class="text-xl font-bold text-primary">Tovarlabs</h3>
                </div>
                <p class="text-gray-300 mb-4">
                    Creamos soluciones digitales completas para impulsar tu negocio.
                </p>
            </div>

            <!-- Contact links -->
            <div>
                <h4 class="text-lg font-semibold mb-4">Contacto</h4>
                <ul class="space-y-2 text-gray-300">
                    <li>
                        <a
                            href="mailto:info@tovarlabs.com"
                            class="hover:text-primary transition-colors"
                        >
                            📧 info@tovarlabs.com
                        </a>
                    </li>
                    <li>
                        <a
                            href="https://wa.me/528143264788"
                            target="_blank"
                            class="hover:text-primary transition-colors"
                        >
                            📱 +52 81 4326 4788
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Services -->
            <div>
                <h4 class="text-lg font-semibold mb-4">Servicios</h4>
                <ul class="space-y-2 text-gray-300">
                    <li>Páginas Web Profesionales</li>
                    <li>Sistemas Web a Medida</li>
                    <li>Automatización de Procesos</li>
                </ul>
            </div>
        </div>

        <div class="border-t border-gray-700 mt-8 pt-8 text-center text-gray-400">
            <p>&copy; {currentYear} Tovarlabs. Todos los derechos reservados.</p>
        </div>
    </div>
</footer>
