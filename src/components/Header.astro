---

---

<nav id="main-nav" class="fixed w-full z-50 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">
            <!-- Logo -->
            <div class="flex-shrink-0">
                <a href="#inicio" class="flex items-center gap-3 group">
                    <img
                        src="/logo.png"
                        alt="Tovarlabs"
                        class="h-10 w-auto transition-transform group-hover:scale-110"
                    />
                    <span
                        class="text-2xl font-bold text-white nav-logo-text hidden sm:block transition-colors"
                    >
                        Tovar<span class="text-primary">labs</span>
                    </span>
                </a>
            </div>

            <!-- Desktop Menu -->
            <div class="hidden md:flex items-center space-x-1">
                <a
                    href="#servicios"
                    data-section="servicios"
                    class="nav-link relative px-4 py-2 text-white hover:text-primary transition-colors font-medium rounded-lg"
                >
                    Servicios
                </a>
                <a
                    href="#tecnologias"
                    data-section="tecnologias"
                    class="nav-link relative px-4 py-2 text-white hover:text-primary transition-colors font-medium rounded-lg"
                >
                    Tecnologías
                </a>
                <a
                    href="#como-trabajamos"
                    data-section="como-trabajamos"
                    class="nav-link relative px-4 py-2 text-white hover:text-primary transition-colors font-medium rounded-lg"
                >
                    Proceso
                </a>
                <a
                    href="#contacto"
                    class="ml-4 bg-primary text-secondary px-6 py-2.5 rounded-xl hover:bg-primary-light transition-all font-semibold shadow-lg shadow-primary/25 hover:shadow-primary/40 hover:-translate-y-0.5"
                >
                    Contactar
                </a>
            </div>

            <!-- Mobile menu button -->
            <div class="md:hidden">
                <button
                    id="mobile-menu-btn"
                    class="text-white hover:text-primary transition-colors p-2"
                    aria-label="Abrir menú"
                >
                    <svg
                        id="menu-icon"
                        class="h-6 w-6 transition-transform duration-300"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                    <svg
                        id="close-icon"
                        class="h-6 w-6 hidden transition-transform duration-300"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile Menu -->
    <div
        id="mobile-menu"
        class="md:hidden overflow-hidden transition-all duration-300 max-h-0 opacity-0"
    >
        <div class="mobile-menu-bg backdrop-blur-xl border-t border-white/10">
            <div class="px-4 py-6 space-y-2">
                <a
                    href="#servicios"
                    data-section="servicios"
                    class="mobile-nav-link block px-4 py-3 text-white hover:text-primary hover:bg-white/5 rounded-xl transition-all font-medium"
                >
                    Servicios
                </a>
                <a
                    href="#tecnologias"
                    data-section="tecnologias"
                    class="mobile-nav-link block px-4 py-3 text-white hover:text-primary hover:bg-white/5 rounded-xl transition-all font-medium"
                >
                    Tecnologías
                </a>
                <a
                    href="#como-trabajamos"
                    data-section="como-trabajamos"
                    class="mobile-nav-link block px-4 py-3 text-white hover:text-primary hover:bg-white/5 rounded-xl transition-all font-medium"
                >
                    Proceso
                </a>
                <a
                    href="#contacto"
                    class="block mt-4 bg-primary text-secondary px-6 py-3 rounded-xl text-center font-semibold hover:bg-primary-light transition-all"
                >
                    Contactar
                </a>
            </div>
        </div>
    </div>
</nav>

<script>
    // Mobile menu toggle
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    mobileMenuBtn?.addEventListener('click', () => {
        const isOpen = !mobileMenu?.classList.contains('max-h-0');

        if (isOpen) {
            // Close menu
            mobileMenu?.classList.add('max-h-0', 'opacity-0');
            mobileMenu?.classList.remove('max-h-96', 'opacity-100');
            menuIcon?.classList.remove('hidden');
            closeIcon?.classList.add('hidden');
        } else {
            // Open menu
            mobileMenu?.classList.remove('max-h-0', 'opacity-0');
            mobileMenu?.classList.add('max-h-96', 'opacity-100');
            menuIcon?.classList.add('hidden');
            closeIcon?.classList.remove('hidden');
        }
    });

    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', (e) => {
            e.preventDefault();
            const href = anchor.getAttribute('href');
            const target = document.querySelector(href || '');
            if (target) {
                target.scrollIntoView({
                    behavior: 'smooth',
                    block: 'start',
                });
                // Close mobile menu after click
                if (mobileMenu) {
                    mobileMenu.classList.add('max-h-0', 'opacity-0');
                    mobileMenu.classList.remove('max-h-96', 'opacity-100');
                    menuIcon?.classList.remove('hidden');
                    closeIcon?.classList.add('hidden');
                }
            }
        });
    });

    // Scroll detection for navbar background
    const nav = document.getElementById('main-nav');
    const navLogoText = document.querySelector('.nav-logo-text');

    let lastScroll = 0;

    window.addEventListener('scroll', () => {
        const currentScroll = window.pageYOffset;

        if (currentScroll > 100) {
            // Scrolled - add background
            nav?.classList.add('nav-scrolled');
            navLogoText?.classList.remove('text-white');
            navLogoText?.classList.add('text-secondary');

            // Update nav links color for scrolled state
            document.querySelectorAll('.nav-link').forEach((link) => {
                link.classList.remove('text-white');
                link.classList.add('text-secondary');
            });
        } else {
            // Top of page - transparent and clear all active states
            nav?.classList.remove('nav-scrolled');
            navLogoText?.classList.remove('text-secondary');
            navLogoText?.classList.add('text-white');

            // Update nav links color for transparent state
            document.querySelectorAll('.nav-link').forEach((link) => {
                link.classList.remove('text-secondary');
                link.classList.add('text-white');
            });

            // Clear all active states when at the top
            navLinks.forEach((link) => {
                link.classList.remove('active');
            });
        }

        lastScroll = currentScroll;
    });

    // Active section detection
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-link, .mobile-nav-link');

    const observerOptions = {
        threshold: 0.3,
        rootMargin: '-100px 0px -66% 0px',
    };

    const observerCallback = (entries: IntersectionObserverEntry[]) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                const sectionId = entry.target.getAttribute('id');

                // Skip marking "inicio" (Hero) as active since it's not in the nav
                if (sectionId === 'inicio') {
                    navLinks.forEach((link) => {
                        link.classList.remove('active');
                    });
                    return;
                }

                // Remove active class from all links
                navLinks.forEach((link) => {
                    link.classList.remove('active');
                });

                // Add active class to current section links
                const activeLinks = document.querySelectorAll(`[data-section="${sectionId}"]`);
                activeLinks.forEach((link) => {
                    link.classList.add('active');
                });
            }
        });
    };

    const sectionObserver = new IntersectionObserver(observerCallback, observerOptions);
    sections.forEach((section) => sectionObserver.observe(section));
</script>

<style>
    /* Navbar background transition */
    #main-nav {
        background: transparent;
    }

    #main-nav.nav-scrolled {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(12px);
        box-shadow:
            0 4px 6px -1px rgba(0, 0, 0, 0.1),
            0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    /* Active link indicator */
    .nav-link.active {
        color: #00ffca !important;
        background: rgba(0, 255, 202, 0.1);
    }

    .nav-link.active::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 30px;
        height: 2px;
        background: #00ffca;
        border-radius: 2px;
    }

    .mobile-nav-link.active {
        color: #00ffca !important;
        background: rgba(0, 255, 202, 0.1);
        border-left: 3px solid #00ffca;
    }

    /* Mobile menu background */
    .mobile-menu-bg {
        background: rgba(32, 70, 107, 0.98);
    }

    /* Smooth transitions */
    .nav-link,
    .mobile-nav-link {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
</style>
